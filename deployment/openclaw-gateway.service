[Unit]
Description=Archive Photo Assistant OpenClaw Gateway
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=__APP_USER__
WorkingDirectory=__APP_DIR__
EnvironmentFile=__APP_DIR__/.env
Environment=MPLCONFIGDIR=/tmp/archive_photo_assistant_mpl
Environment=XDG_CACHE_HOME=/tmp/archive_photo_assistant_cache
ExecStart=__OPENCLAW_BIN__ gateway
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
